# ── Aiden Configuration ──────────────────────────────────────

# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Optional: Model selection (default: claude-sonnet-4-20250514)
# MODEL=claude-opus-4-20250514
# MODEL=claude-haiku-3-5-20241022

# Optional: Generation parameters
# MAX_TOKENS=4096
# TEMPERATURE=0.7

# Optional: Server
# HOST=0.0.0.0
# PORT=8000

# Optional: Search provider
# SEARCH_PROVIDER=duckduckgo

# Optional: Data directory
# AIDEN_DATA_DIR=./data

# ── 企业微信 (WeCom) Integration ─────────────────────────────
# 在 企业微信后台 → 应用管理 → 自建应用 中获取
# 回调配置参见: https://developer.work.weixin.qq.com/document/path/90968
# WECOM_CORP_ID=wwxxxxxxxx
# WECOM_AGENT_ID=1000001
# WECOM_SECRET=xxxxxxxxxxxxxxxxxxxx
# WECOM_TOKEN=xxxxxxxxxx
# WECOM_ENCODING_AES_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: Verbose logging
# VERBOSE=1
